 obviously quite tired.</field></shadow></value><next><block type="device_pause" id="U7S*^WnYL+@QYDwbC2UV"><value name="pause"><shadow type="timePicker" id="1BH0~?x%U7s!;R=#aiWC"><field name="ms">1000</field></shadow></value><next><block type="game_dialog_set_text_color" id="(qR-U^cpnwWrQ6s@ZkU#"><value name="color"><shadow type="colorindexpicker" id="ost928,7_T)eVPgzG|!u"><field name="index">15</field></shadow></value><next><block type="game_show_long_text" id="N[~sxQWM7Ui8pPA*Fcq_"><field name="layout">DialogLayout.Bottom</field><value name="str"><shadow type="text" id="R{ktS=~tT[8otRV?4I[m"><field name="TEXT">Good to hear,</field></shadow></value><next><block type="game_show_long_text" id="KhKM|v|Zz2CTC1*p`SxT"><field name="layout">DialogLayout.Bottom</field><value name="str"><shadow type="text" id="rU+7bgH?6s)|K]73)gu_"><field name="TEXT">Anyway, we need you to do one last job for us today.</field></shadow></value><next><block type="device_pause" id="T6}K3]aP1cf?LyM8Fv*D"><value name="pause"><shadow type="timePicker" id="e;q/LcE|vrDm0AP!f_F)"><field name="ms">500</field></shadow></value><next><block type="game_dialog_set_text_color" id="D4#Apw4Y[M-|H$a4,aRR"><value name="color"><shadow type="colorindexpicker" id=";FgCi)zAt~U*`TK,6ujx"><field name="index">4</field></shadow></value><next><block type="game_show_long_text" id="wGGgF_m8S+!9*;Ly+F0e"><field name="layout">DialogLayout.Bottom</field><value name="str"><shadow type="text" id="cR1ZlSZ%Um}=dxZkr0h$"><field name="TEXT">What?!?</field></shadow></value><next><block type="game_show_long_text" id="}~)OF^(1[hPw7fGZQg#D"><field name="layout">DialogLayout.Bottom</field><value name="str"><shadow type="text" id="9kt`NMHiC[{#W#%A~7He"><field name="TEXT">I can barely keep my eyes open!</field></shadow></value><next><block type="device_pause" id="hj~`n;*oi]p}1%rlo41!"><value name="pause"><shadow type="timePicker" id="A;nT_+=:?4bXS?)T[wWF"><field name="ms">200</field></shadow></value><next><block type="game_dialog_set_te