><field name="VAR" id="*O)_GyB.=[pLs~c7+qQX">Name</field></block></value><value name="ADD2"><shadow type="text" id="%^pZ;`Fj]%Z:S]c#p!z)"><field name="TEXT">!</field></shadow></value></block></value><next><block type="game_show_long_text" id="I,;exZtbkb.1%IGq/7~^"><field name="layout">DialogLayout.Bottom</field><value name="str"><shadow type="text" id="`@wN*Iy$HW[-!C%LMErB"><field name="TEXT">What have you been doing all night?</field></shadow></value><next><block type="game_dialog_set_text_color" id="B{XK.c#cNNPK=d!9_w)v"><value name="color"><shadow type="colorindexpicker" id="D1*}boBp%J{LtQZ[Q%6^"><field name="index">4</field></shadow></value><next><block type="game_show_long_text" id="D)ghDc*iiR9K=-u7gyyJ"><field name="layout">DialogLayout.Bottom</field><value name="str"><shadow type="text" id="k0Or_IJ/nK^qmMWFw3pb"><field name="TEXT">What do you mean?!?</field></shadow></value><next><block type="game_show_long_text" id="5aB=ABh`K?jLBVd}=^%G"><field name="layout">DialogLayout.Bottom</field><value name="str"><shadow type="text" id="=z6pS-1*=I1)^oO8ob]="><field name="TEXT">You saw!</field></shadow></value><next><block type="game_show_long_text" id="!:tv4^D5dqrT32-ut(/4"><field name="layout">DialogLayout.Bottom</field><value name="str"><shadow type="text" id="Ln,vnXNU61g9STk.4{32"><field name="TEXT">You also blatantly betrayed me!</field></shadow></value><next><block type="game_dialog_set_text_color" id="Ii3PtUr?qj2neLQWLZB,"><value name="color"><shadow type="colorindexpicker" id="MM33|t-Q@KZx9Y1]wDuG"><field name="index">15</field></shadow></value><next><block type="game_show_long_text" id="qgq]=Zzb:SOI@xMdX$4?"><field name="layout">DialogLayout.Bottom</field><value name="str"><shadow type="text" id="deUrFn`:z1TABF/k8(nl"><field name="TEXT">I haven't heard from you since you were last here.</field></shadow></value><next><block type="game_show_long_text" id=",+?pOD|M#j;gt|j~u02i"><field name="layout">DialogLayout.Bottom</field><value name="str"><shadow type="text" id="BfnHPI5i1DZ);H#*kFB}"><field name="TEXT">You did also just set fire to one of our factories,</field></shadow></value><next><block type="game_show_long_text" id="^Pl^|nmGi%nLDUoK}blh"><field name="layout">DialogLayout.Bottom</field><value name="str"><shadow type="text" id=";{P@~cu):.q5%`hWW-J+"><field name="TEXT">for seemingly no reason.</field></shadow></value><next><block type="game_dialog_set_text_color" id="6A94s;$bJRHb?O4_|(rt"><value name="color"><shadow type="colorindexpicker" id="/.%TG8mAJn@M8G+GshGE"><field name="index">4</field></shadow></value><next><block type="game_show_long_text" id="j?OP)2bP`WLybM?9_w09"><field name="layout">DialogLayout.Bottom</field><value name="str"><shadow type="text" id="Ru[%N#q*,mocl?T()G|W"><field name="TEXT">There was a thing, a robot!</field></shadow></value><next><block type="game_dialog_set_text_color" id="w8%*[(BG|{ePKfH5Am+N"><value name="color"><shadow type="colorindexpicker" id="67HUp?|[E=w^RvR9/{U("><field name="index">15</field></shadow></value><next><block type="game_show_long_text" id="ZP~%q3U/X`tqs*i+]N;B"><field name="layout">DialogLayout.Bottom</field><value name="str"><shadow type="text" id="O8QJ$fA59HKN[n^rAGGL"><field name="TEXT">Sure thing, pal.</field></shadow></value><next><block type="game_show_long_text" id="4q0,zQ?_|syfObj,5Gj("><field name="layout">DialogLayout.Bottom</field><value name="str"><shadow type="text" id="k?VcEG?{S%z^;8s=NlOq"><field name="TEXT">We are sorry but we are terminating your contract.</field></shadow></value><next><block type="game_show_long_text" id="$l:!gGS6#|$5~Rb3%AmH"><field name="layout">DialogLayout.Bottom</field><value name="str"><shadow type="text" id=":1~AShxSyFVHIr*jF{#2"><field name="TEXT">You are no longer part of this company.</field></shadow></value><next><block type="game_dialog_set_text_color" id="gB0nR.gIZ9RoO]mi(2aR"><value name="color"><shadow type="colorindexpicker" id="wqu`SN-aUo)LCf9Clp-E"><field name="index">4</field></shadow></value><next><block type="gam