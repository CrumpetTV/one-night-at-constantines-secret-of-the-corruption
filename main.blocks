="NUM">0</field></shadow></value></block></value><statement name="DO0"><block type="game_dialog_set_text_color" id="dhPDjw(.)5lro^I#~na["><value name="color"><shadow type="colorindexpicker" id="9iAz(G/hc+wVxoYjZ{Z,"><field name="index">15</field></shadow></value><next><block type="game_show_long_text" id="K1gV]f=m-_dj}O}+-ffL"><field name="layout">DialogLayout.Bottom</field><value name="str"><shadow type="text" id=":);iG%TegK:HiEs%5829"><field name="TEXT">Hey! Guess what?</field></shadow></value><next><block type="game_show_long_text" id="Y(mfM;DHWjR.:WfQiC!_"><field name="layout">DialogLayout.Bottom</field><value name="str"><shadow type="text" id="B*s]0V00[?i7|olIt6i#"><field name="TEXT">I got the power back on, so no more torch!</field></shadow></value><next><block type="game_show_long_text" id="Bz-0y+,2pGZ.{}.T?~Ef"><field name="layout">DialogLayout.Bottom</field><value name="str"><shadow type="text" id="S/Kx5^z.V-*jUB(H|,eL"><field name="TEXT">Hooray!</field></shadow></value><next><block type="game_dialog_set_text_color" id="snWgl.s[EstULm@udtOp"><value name="color"><shadow type="colorindexpicker" id="_0;T{bvrSc0Ff-YD~SoH"><field name="index">4</field></shadow></value><next><block type="game_show_long_text" id="]0-a85s-8}n3`v,A_=~U"><field name="layout">DialogLayout.Bottom</field><value name="str"><shadow type="text" id="zK-(7QH+y}kTe-gro}r#"><field name="TEXT">Yeah, is this really it?</field></shadow></value><next><block type="game_dialog_set_text_color" id="td;h8}?:82DNzV4?A?Ub"><value name="color"><shadow type="colorindexpicker" id="/m:#5v_buOw{aeC6h8gj"><field name="index">15</field></shadow></value><next><block type="game_show_long_text" id="QvbV%w#X_M]JQf$y1PsD"><field name="layout">DialogLayout.Bottom</field><value name="str"><shadow type="text" id="07*vRAG;%}putu~HuH6m"><field name="TEXT">Don't see what else there'd be...</field></shadow></value><next><block type="game_show_long_text" id="]*s`;Oke]Za-?Yv~Mn!+"><field name="layout">DialogLayout.Bottom</field><value name="str"><shadow type="text" id="RpshN;J)eX(-?T-aK}{k"><field name="TEXT">Alright</field></shadow><block type="text_join" id="#VdJ:9AH6Hets|C[KdU-"><mutation items="3"></mutation><value name="ADD0"><shadow type="text" id="3GO*NwS~bwu,5bh(h~x-"><field name="TEXT">So </field></shadow></value><value name="ADD1"><shadow type="text" id="p4u)|OLzzqZYh6x~l]_o"><field name="TEXT">World</field></shadow><block type="variables_get" id="P*-e,euG[BM54z;TmotX"><field name="VAR" id="*O)_GyB.=[pLs~c7+qQX">Name</field></block></value><value name="ADD2"><shadow type="text" id="SbJ0ychYb;.Qv_l8ZAOK"><field name="TEXT">...</field></shadow></value></block></value><next><block type="game_show_long_text" id="Lia?h_#{6k9Qr/l?0vfB"><field name="layout">DialogLayout.Bottom</field><value name="str"><shadow type="text" id="`nq_801?_DC7IP!h,X9S"><field name="TEXT">I guess that's it then.</field></shadow></value><next><block type="game_show_long_text" id="=?8X/?o[|Z4_g~Kr!1oT"><field name="layout">DialogLayout.Bottom</field><value name="str"><shadow type="text" id="@[Q#,L`DImdVt_g,^k9^"><field name="TEXT">It's all over.</field></shadow></value><next><block type="game_show_long_text" id="f|Ykm]2T?Z5qHk{$Y04T"><field name="layout">DialogLayout.Bottom</field><value name="str"><shadow type="text" id="_9tsEHb{j=Rb=Rf~:|ks"><field name="TEXT">There should be a lever for the door</field></shadow></value><next><block type="game_show_long_text" id="I3cx0q.=GD.H#S8.rFO."><field name="layout">DialogLayout.Bottom</field><value name="str"><shadow type="text" id="o1gPIq(cV31L!Q$Ddoe5"><field name="TEXT">in the security office.</field></shadow></value><next><block type="game_show_long_text" id="p`6ZA.k`l_7*Q8M`*sY6"><field name="layout">DialogLayout.Bottom</field><value name="str"><shadow type="text" id=";[V%ZmWvi!E,`6[O@$eZ"><field name="TEXT">Go through the door, down the hallway,</field></shadow></value><next><block type="game_show_long_text" id=";ziWue{83VZ=b$u#cc6h"><field name="layout">DialogLayout.Bottom</field><value name="str"><shadow type="text" id="xJ)1|)Es+63cmcKs+pLA"><field name="TEXT">send the schematic...</field></shadow></value><next><block type="game_show_long_text" id="oe#adEo^#_LbAQaxi#B;"><field name="layout">DialogLayout.Bottom</field><value name="str"><shadow type="text" id="~js7d{kIS?$IfK:R|[)P"><field name="TEXT">and...</field></shadow></value><next><block type="game_show_long_text" id="azDm)~Omsgm_{ej-Kq]+"><field name="layout">DialogLayout.Bottom</field><value name="str"><shadow type="text" id="R-Ozah-z;pbfu3|z1.I/"><field name="TEXT">I'll speak to you in the van...</field></shadow></value><next><block type="game_show_long_text" id="8@LXEuVq]m7;H:9LEN~("><field name="layout">DialogLayout.Bottom</field><value name="str"><shadow type="text" id=";hRHs$P.uXoh-@mzsek:"><field name="TEXT">Goodbye.</field></shadow></value></block></next></block></next></block></next></block></next></block></next></block></next></block></next></block></next></block></next></block></next></block></next></block></next></block></next></block></next></block></next></block></next></block></next></block></statement><value name="IF1"><shadow type="logic_boolean" id="|HS!z;(/6w,Vk]R5P]Qs" disabled-reasons="ORPHANED_BLOCK,MANUALLY_DISABLED"><field name="BOOL">FALSE</field></shadow><block type="logic_compare" id="dn1){7V@dRT:6Qu0WD)C"><field name="OP">EQ</field><value name="A"><shadow type="math_number" id="~HnjZwS%pQfZUdbKpyVM" disabled-reasons="MANUALLY_DISABLED"><field name="NUM">0</field></shadow><block type="variables_get" id="I_Ilncl4+yB+J!:[:oT6"><field name="VAR" id="MFmi/~~XpywPH;dWtB0D">GoodEnding</field></block></value><value name="B"><shadow type="math_number" id="Juy;LBoa#869utIL%Exo"><field name="NUM">1</field></shadow></value></block></value><statement name="DO1"><block type="game_dialog_set_text_color" id="`HG3?RKOH}emISY|,rj7"><value name="color"><shadow type="colorindexpicker" id="/rZ3},[5=r.k/K:u|j#2"><field name="index">15</field></shadow></value