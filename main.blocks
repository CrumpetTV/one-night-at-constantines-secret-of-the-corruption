5[4(!Q(["><field name="layout">DialogLayout.Bottom</field><value name="str"><shadow type="text" id="3z)ZmWMzGx$nadzI.o+V"><field name="TEXT">What?</field></shadow></value><next><block type="game_dialog_set_text_color" id="%MRHrLk2Mg+k#luJ9jyF"><value name="color"><shadow type="colorindexpicker" id=",N|$luvJ9:1N7kf2Vuya"><field name="index">15</field></shadow></value><next><block type="game_show_long_text" id="]k*L1hG)$A9tm_[]pR//"><field name="layout">DialogLayout.Bottom</field><value name="str"><shadow type="text" id="(7:|C_[i$vKUQpj{S4FP"><field name="TEXT">You did open the shutters, but the power is low.</field></shadow></value><next><block type="game_show_long_text" id="?j$;cUI},C.$|Uh``Wp."><field name="layout">DialogLayout.Bottom</field><value name="str"><shadow type="text" id="=%,fo0z0Nu-[uXB++X!2"><field name="TEXT">That was basically the last of it.</field></shadow></value><next><block type="game_show_long_text" id="~bwZMg+mjSqmHB`pO^nI"><field name="layout">DialogLayout.Bottom</field><value name="str"><shadow type="text" id="Gpk1Tp@_b?[%b/^L9rH6"><field name="TEXT">It should still power some parts of the facility,</field></shadow></value><next><block type="game_show_long_text" id="2ybK#=leE?SZuZEFWshO"><field name="layout">DialogLayout.Bottom</field><value name="str"><shadow type="text" id="cw;*~Nq0QEK[2Z-^oA}F"><field name="TEXT">But, important to you, the lights are out.</field></shadow></value><next><block type="game_dialog_set_text_color" id="Vr_TOq6t}cUAWVeh?S6["><value name="color"><shadow type="colorindexpicker" id="kwpruZQV~lpNSu~!n6Vg"><field name="index">4</field></shadow></value><next><block type="game_show_long_text" id="?R:wSz*E1q1rlKji.1x="><field name="layout">DialogLayout.Bottom</field><value name="str"><shadow type="text" id="1i]mXYy$UN2M3ycUmD]H"><field name="TEXT">Wait, what?</field></shadow></value><next><block type="game_dialog_set_text_color" id="ud@%1B2TP/Dx[F?z1KNl"><value name="color"><shadow type="colorindexpicker" id="`$%~2)cSB+VPp_Vf91^p"><field name="index">15</field></shadow></value><next><block type="game_show_long_text" id=";E*4=tH3en07!mB{f?ZC"><field name="layout">DialogLayout.Bottom</field><value name="str"><shadow type="text" id="iPH0JnBp:Z:|MC.nAgsr"><field name="TEXT">Even, worse you alerted The Corruption.</field></shadow></value><next><block type="game_show_long_text" id="EcUnKMP7m!dpT+?77sl)"><field name="layout">DialogLayout.Bottom</field><value name="str"><shadow type="text" id="@`MzynhZ1W;I$@y.k2Fx"><field name="TEXT">It will be coming.</field></shadow></value><next><block type="game_show_long_text" id="*apkMLg_{Wged7;izQ}e"><field name="layout">DialogLayout.Bottom</field><value name="str"><shadow type="text" id="5Qa%XKUp2K*B6KrRxJ%;"><field name="TEXT">Good luck.</field></shadow></value><next><block type="spritesetimage" id="b%p1;gTUUrzEmFmYeC]}"><value name="sprite"><block type="variables_get" id=";@stg[ES-fn^YPXu.ZS$"><field name="VAR" id="!~lHigYd%j.^8r{+ZpT7">Darkness Overlay</field></block></value><value name="img"><shadow type="screen_image_picker" id="CE^(zJmn{lT7-|k(zb)A"><field name="img">img`
