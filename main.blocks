eld><value name="str"><shadow type="text" id="B;+U.%{V6ToB!6RJuGg2"><field name="TEXT">...</field></shadow></value><next><block type="game_show_long_text" id="i*?}2JA6_Hb)b4n:s_d7"><field name="layout">DialogLayout.Bottom</field><value name="str"><shadow type="text" id=";-a3I;%dc+@4_6f-4w?X"><field name="TEXT">What was that noise?</field></shadow></value><next><block type="game_dialog_set_text_color" id="b*8V2Cq@0`acsCz==@vL"><value name="color"><shadow type="colorindexpicker" id="d73A8M`Q+b9B3Zzo}7dB"><field name="index">15</field></shadow></value><next><block type="game_show_long_text" id="qqYxa-$6]1:z#gj@G+R7"><field name="layout">DialogLayout.Bottom</field><value name="str"><shadow type="text" id="OofOSdYDx{fOCK*o-x2s"><field name="TEXT">Uh oh.</field></shadow></value><next><block type="game_dialog_set_text_color" id="fCWX6ft2@GBSg]Cl!kgb"><value name="color"><shadow type="colorindexpicker" id="D#`T!SZQ.`{q.L6UHyv:"><field name="index">4</field></shadow></value><next><block type="game_show_long_text" id="4[TYs|}Z27qhASBeQPNe"><field name="layout">DialogLayout.Bottom</field><value name="str"><shadow type="text" id="t!x}D+g,*v~2#]KD[n]g"><field name="TEXT">What do you mean uh oh?</field></shadow></value><next><block type="game_dialog_set_text_color" id="!sMDv,tXXk0%WcyeH3:("><value name="color"><shadow type="colorindexpicker" id="@CRR(Yc+~rRxAI[WX%In"><field name="index">15</field></shadow></value><next><block type="game_show_long_text" id="LnnGSx#~_OB+{L3Xa%M7"><field name="layout">DialogLayout.Bottom</field><value name="str"><shadow type="text" id=".[7`TvXPkI65lPZODl?9"><field name="TEXT">That is one of the animatronics you're getting for us.</field></shadow></value><next><block type="game_dialog_set_text_color" id="EZQ74y}+z,3JE[}P,2Oy"><value name="color"><shadow type="colorindexpicker" id="Ian,=:[3xV|9`=/E)$I8"><field name="index">4</field></shadow></value><next><block type="game_show_long_text" id="`z?(B`Wd(PWUbUK`Tqi@"><field name="layout">DialogLayout.Bottom</field><value name="str"><shadow type="text" id="Ikei(6/7Pl*wKwU)]%-E"><field name="TEXT">Is it dangerous?</field></shadow></value><next><block type="game_dialog_set_text_color" id="_H[%#u5]by|wMj^7MkB?"><value name="color"><shadow type="colorindexpicker" id="]Qo#EBZY3;`(8iNIVo`U"><field name="index">15</field></shadow></value><next><block type="game_show_long_text" id=":{,dFy|N?+8E3NZbJvUz"><field name="layout">DialogLayout.Bottom</field><value name="str"><shadow type="text" id="`8!C-1,|ue{UE|c.qNe`"><field name="TEXT">Kind of, maybe...</field></shadow></value><next><block type="game_show_long_text" id=")Q:}GF;dgA|(V~e;6kCO"><field name="layout">DialogLayout.Bottom</field><value name="str"><shadow type="text" id=";j92zzG)-G48Hsbd03`M"><field name="TEXT">Yes.</field></shadow></value><next><block type="game_dialog_set_text_color" id="!/Lc/}5t4p#t_lwR1rzL"><value name="color"><shadow type="colorindexpicker" id="0+iST]%vKqJ26T1eE)`G"><field name="index">4</field></shadow></value><next><block type="game_show_long_text" id="uJ8!*hm2AV*jwL_]T@M,"><field name="layout">DialogLayout.Bottom</field><value name="str"><shadow type="text" id=".Gw8ok`RJ:luk%4m;P)6"><field name="TEXT">What???</field></shadow></value><next><block type="game_dialog_set_text_color" id="?{)(H1h}36xl5{(}=L{H"><value name="color"><shadow type="colorindexpicker" id="CYA0Z#Uc#=!=f1H,aJUF"><field name="index">15</field></shadow></value><next><block type="game_show_long_text" id="r:=A#]NaPd}5S#hq53TQ"><field name="layout">DialogLayout.Bottom</field><value name="str"><shadow type="text" id="kn86@C[IB,N*O]}W:cZ["><field name="TEXT">Okay, think fast...</field></shadow></value><next><block type="game_show_long_text" id="t`Xmnu?Z;{5udCds.iLs"><field name="layout">DialogLayout.Bottom</field><value name="str"><shadow type="text" id="p,#WMlsdRP.q;d)I);kN"><field name="TEXT">Um... there should be a locker on your left.</field></shadow></value><next><block type="game_show_long_text" id="x+~Y9e^4=BdG^~26Ci5-"><field name="layout">DialogLayout.Bottom</field><value name="str"><shadow type="text" id="kRyZN(:_v8H}ZYxk;MK["><field name="TEXT">Once you've done that, head to the back of the room.</field></shadow></value><next><block type="game_show_long_text" id="OX/+x!BYAr7Pm0$iEm}z"><field name="layout">DialogLayout.Bottom</field><value name="str"><shadow type="text" id="eQ.jWJ,Bs#?LT5BFteSC"><field name="TEXT">You should be able to get to the next section.</field></shadow></value><next><block type="game_show_long_text" id="2LG3F$tF_V|4Ua{{HY:r"><field name="layout">DialogLayout.Bottom</field><value name="str"><shadow type="text" id="edou{%Ltv/Xrou7bwN2u"><field name="TEXT">Head over there, and do it quick.</field></shadow></value><next><block type="game_dialog_set_text_color" id="j0RM3emnobk=|aZzyQRP"><value name="color"><shadow type="colorindexpicker" id="jh]%:urhbj;]-!+mm$T;"><field name="index">4</field></shadow></value><next><block type="game_show_long_text" id="0V4xkjYwIm)H_$Q./_9("><field name="layout">DialogLayout.Bottom</field><value name="str"><shadow type="text" id="Cl7G/E0l$!EG}AIxtJ4S"><field name="TEXT">You're the worst.</field></shadow></value><next><block type="gameSplash" id="8XxMTl8!NAZ4M$(=9xAm"><mutation xmlns="http://www.w3.org/1999/xhtml" _expanded="0" _input_init="true"></mutation><value name="title"><shadow type="text" id="xVWS4iWi)puQyWAJ2l`-"><field name="TEXT">A/Z = Sprint</field></shadow></value><value name="subtitle"><shadow type="text" id="J-AWjvU@-xGR/,^8IDit"><field name="TEXT"></field></shadow></value></block></next></block></next></block></next></block></next></block></next></block></next></block></next></block></next></block></next></block></next></block></next></block></next></block></next></block></next></block></next></block></next></block></next></block></next></block></next></block></next></block></next></block></next></block></next></block></next></block></next></block></next></block></statement><value name="IF1"><shadow type="logic_boolean"