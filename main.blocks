XT">It seems to have taken on a new suit.</field></shadow></value><next><block type="game_dialog_set_text_color" id="vl{MqM9`.yT5NmnEDx{P"><value name="color"><shadow type="colorindexpicker" id="CIX~mTmeCkN)=q@5K~GQ"><field name="index">4</field></shadow></value><next><block type="game_show_long_text" id="=@5:R|b7y(*?^v#3ij^9"><field name="layout">DialogLayout.Bottom</field><value name="str"><shadow type="text" id="urL*2W#/=LU}/e//N^qp"><field name="TEXT">I don't see any lockers...</field></shadow></value><next><block type="game_show_long_text" id=".P%hpxfD}tBW3d|~o/l9"><field name="layout">DialogLayout.Bottom</field><value name="str"><shadow type="text" id="VeDU#KN{Rw$;xy(H]KIW"><field name="TEXT">What do I do???</field></shadow></value><next><block type="game_dialog_set_text_color" id="mqo[dgy[%dJ@E+k2xA1r"><value name="color"><shadow type="colorindexpicker" id="*a_;f!rY{4sg^@4!bFvk"><field name="index">15</field></shadow></value><next><block type="game_show_long_text" id="Ql.y-H@5`XQ6No4YydW#"><field name="layout">DialogLayout.Bottom</field><value name="str"><shadow type="text" id="/yha4^_-gD,bADcCz8W!"><field name="TEXT">My best advice is run.</field></shadow></value><next><block type="game_show_long_text" id="uBEo|26z9^h#*z|~*#Bl"><field name="layout">DialogLayout.Bottom</field><value name="str"><shadow type="text" id="@N5|A~Ul`PTRy_FIT%/p"><field name="TEXT">As fast as you can.</field></shadow></value><next><block type="game_show_long_text" id="+N^}oATQZ=Ry~ETIu5zh"><field name="layout">DialogLayout.Bottom</field><value name="str"><shadow type="text" id="xp7@kFC{!K[;koZ!LnJP"><field name="TEXT">Remember to sprint!</field></shadow></value><next><block type="gameSplash" id="Bm6,i030c;Z0}[RU3U32"><mutation xmlns="http://www.w3.org/1999/xhtml" _expanded="0" _input_init="true"></mutation><value name="title"><shadow type="text" id="Ze+C]Mv)*9k1CHX[c+lF"><field name="TEXT">A/Z = Sprint</field></shadow></value><value name="subtitle"><shadow type="text" id="A:.vwtzG-DV