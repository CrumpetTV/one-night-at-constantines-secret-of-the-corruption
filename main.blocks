y, some good news.</field></shadow></value><next><block type="game_dialog_set_text_color" id="Z91_BH2A[XJx`NU+}R97"><value name="color"><shadow type="colorindexpicker" id="TKfVIv8P+JsYLY}@~tCc"><field name="index">15</field></shadow></value><next><block type="game_show_long_text" id="1*6!eeM=HX$$TCNfH.6."><field name="layout">DialogLayout.Bottom</field><value name="str"><shadow type="text" id="JW4:RHsO7EE2S8e@R=Oh"><field name="TEXT">Additionally, I've located a torch in the next room.</field></shadow></value><next><block type="game_dialog_set_text_color" id="i{h.u__0H.e@6vT;RS0X"><value name="color"><shadow type="colorindexpicker" id="~dizcm~TgFarU8-#9O0^"><field name="index">4</field></shadow></value><next><block type="game_show_long_text" id="I.`!^Y1D9/7[E/rRW`|T"><field name="layout">DialogLayout.Bottom</field><value name="str"><shadow type="text" id="_Ss?|L?ODSTNsezUS){q"><field name="TEXT">Okay, well that's good.</field></shadow></value><next><block type="game_dialog_set_text_color" id="a+jI]#0A[Yndws.C_Ena"><value name="color"><shadow type="colorindexpicker" id="4C18^_7Vk$IoO[kF%T`j"><field name="index">15</field></shadow></value><next><block type="game_show_long_text" id="X4h{~_P?_!{(jT2bC8;/"><field name="layout">DialogLayout.Bottom</field><value name="str"><shadow type="text" id="JTh6drGV:|i9A1ImUx#c"><field name="TEXT">You bet it is!</field></shadow></value><next><block type="game_show_long_text" id="PLe.u=Cc{NBfAimcd{!M"><field name="layout">DialogLayout.Bottom</field><value name="str"><shadow type="text" id="Y/?vwhUb7`2`/HV(P]mB"><field name="TEXT">The bad news is that the lights will get dimmer.</field></shadow></value><next><block type="game_dialog_set_text_color" id="k#QI-dA4nDrU?FL_ozHl"><value name="color"><shadow type="colorindexpicker" id="!ZJp8IV.2zoYd{9nd+dS"><field name="index">4</field></shadow></value><next><block type="game_show_long_text" id="ydau0CLG2;8)iWa3xT_n"><field name="layout">DialogLayout.Bottom</field><value name="str"><shadow type="text" id="d51A-1GyS.LeBCtrM}|`"><field name="TEXT">Well that's not as good.</field></shadow></value><next><block type="game_dialog_set_text_color" id="!(QI]*Jtx(ShfFyz`fQg"><value name="color"><shadow type="colorindexpicker" id="]`[9+wJwET4+S6Y$a.C."><field name="index">15</field></shadow></value><next><block type="game_show_long_text" id="hksRH:o/yQUq8RY0=AU@"><field name="layout">DialogLayout.Bottom</field><value name="str"><shadow type="text" id="CzPaBD2[^rX6wWBB8hj;"><field name="TEXT">Yeah...</field></shadow></value></block></next></block></next></block></next></block></next></block></next></block></next></block></next></block></next></block></next></block></next></block></next></block></next></block></next></block></next></block></next></block></next></block></next></block></next></block></next></block></next></block></statement><value name="IF3"><shadow type="logic_boolean" id="r_4I/uqjHstl5qY._HrU"><field name="BOOL">FALSE</field></shadow><block type="logic_compare" id="Rc~43}uf^+0a{C7rd#7g"><field name="OP">EQ</field><value name="A"><shadow type="math_number" id="%Ko-#Xx[RZ,~#OB9.quP"><field name="NUM">0</field></shadow><block type="variables_get" id="PN#|8uP_ttc^-CU,CIF:"><field name="VAR" id="`0y7@dScelI^[F5;qT|y">SavePoint</field></block></value><value name="B"><shadow type="math_number" id="8h|67^5~S9:42[G$FklG"><field name="NUM">4</field></shadow></value></block></value><statement name="DO3"><block type="game_dialog_set_text_color" id=",I:8C[P6od[x9((%N3|E"><value name="color"><shadow type="colorindexpicker" id="[Ljmih8J3pFv=[ObBage"><field name="index">15</field></shadow></value><next><block type="game_show_long_text" id="Pmy@%Q+5.ngw@}9Ii!A1"><field name="layout">DialogLayout.Bottom</field><value name="str"><shadow type="text" id="b#T6_dIG-INwr(lSlwXU"><field name="TEXT">How we doing?</field></shadow></value><next><block type="game_dialog_set_text_color" id="cVsqD$)yw`L`(?-B6(s?"><value name="color"><shadow type="colorindexpicker" id="Y0442GB^+CL5s:L*Z.I}"><field name="index">4</field></shadow></value><next><block type="game_show_long_text" id="lB??tSN`MWdPW_5J|!qn"><field name="layout">DialogLayout.Bottom</field><value name="str"><shadow type="text" id=")A@C-U6CR#ItKkl*D90B"><field name="TEXT">What do you mean 'How we doing'???</field></shadow></value><next><block type="game_show_long_text" id=";5?*NO)XP5dbZbmOFWPN"><field name="layout">DialogLayout.Bottom</field><value name="str"><shadow type="text" id="g].w_tRn$?Y%y66n5nD4"><field name="TEXT">Did you not see that amalgamation that just chased me?</field></shadow></value><next><block type="game_dialog_set_text_color" id="EG$}s8uMr9d:kNNmP/OH"><value name="color"><shadow type="colorindexpicker" id="gOHn{c@.-]VW_Y~l!)rC"><field name="index">15</field></shadow></value><next><block type="game_show_long_text" id="HDf~tEeMC!;0Nk1%c.2}"><field name="layout">DialogLayout.Bottom</field><value name="str"><shadow type="text" id="N.qjDYxs`gWC+g*,8NN;"><field name="TEXT">I didn't see The Corruption in the area,</field></shadow></value><next><block type="game_show_long_text" id="?MyEkg|wjv{cuf8Zr?,f"><field name="layout">DialogLayout.Bottom</field><value name="str"><shadow type="text" id="lw@E-btwn+yxM5um#y3]"><field name="TEXT">therefore I wasn't paying attention.</field></shadow></value><next><block type="game_show_long_text" id="4/;!b9{Sq8/K4H,Fn)!;"><field name="layout">DialogLayout.Bottom</field><value name="str"><shadow type="text" id="4q%Rd:`PJixMR;A/uV9k"><field name="TEXT">You probably ran into some old suits of ours.</field></shadow></value><next><block type="game_show_long_text" id="!?jgF?zOGn_n|lGWo)FH"><field name="layout">DialogLayout.Bottom</field><value name="str"><shadow type="text" id="v=HqG==)`vB`Bg[*E7+W"><field name="TEXT">We discarded them after a failed experiment,</field></shadow></value><next><block type="game_show_long_text" id="c:J#qnGS0FT7/%sS}ZTx"><field name="layout">DialogLayout.Bottom</field><value name="str"><shadow type="text" id="LFH:{g%;B3n8OYXSFG-@"><field name="TEXT">but they never discarded us.</field></shadow></value><next><block type="game_show_long_text" id="%u?Co@)c:aT!iF=o+}u/"><field name="layout">DialogLayout.Bottom</field><value name="str"><shadow type="text" id="21xlGYn3?yQe(J(ACB*)"><field name="TEXT">Don't worry, you shouldn't have to deal with them again.</field></shadow></value><next><block type="game_dialog_set_text_color" id="6=QA8Yhi6Vex;HyzDdb6"><value name="color"><shadow type="colorindexpicker" id="*+{Ws6ADQE)U7OVLZHJW"><field name="index">4</field></shadow></value><next><block type="game_show_long_text" id="DBNV^wbQ}?JYB$9?hG,V"><field name="layout">DialogLayout.Bottom</field><value name="str"><shadow type="text" id="(irkI|LlB0PE;feri4qq"><field name="TEXT">Fine, guess I'll move on then.</field></shadow></value></block></next></block></next></block></next></block></next></block></next></block></next></block></next></block></next></block></next></block></next></block></next></block></next></block></next></block></statement><value name="IF4"><shadow type="logic_boolean" id="S_Yg:lM_JiOVv+:#Y_ob"><field name="BOOL">FALSE</field></shadow><block type="logic_compare" id="%s$cC8EiAK~*QIS*8xYi"><field name="OP">EQ</field><value name="A"><shadow type="math_number" id="ObDY@6B9Sy!a_9cUV@|@"><field name="NUM">0</field></shadow><block type="variables_get" id="80J=;a$yBU!1|R`_`ItA"><field name="VAR" id="`0y7@dScelI^[F5;qT|y">SavePoint</field></block></value><value name="B"><shadow type="math_number" id="I/R}9?ACjnW!x@{T041R"><field name="NUM">5</field></shadow></value></block></value><statement name="DO4"><block type="game_dialog_set_text_color" id="mRziiytv,w-awMvJqEwq"><value name="color"><shadow type="colorindexpicker" id="#EqZ*[,)xIQUsXki/aH+"><field name="index">15</field></shadow></value><next><block type="game_show_long_text" id="6`tBKd%-#kKAyydDp9a1"><field name="layout">DialogLayout.Bottom</field><value name="str"><shadow type="text" id="g-xc97?:%b!fxmQchC1x"><field name="TEX